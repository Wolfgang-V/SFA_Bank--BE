<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SFA Bank - Debit Alert</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f8fafc;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f8fafc;">
        <tr>
            <td style="padding: 40px 20px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 600px; margin: 0 auto; background-color: white; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); overflow: hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 32px 32px 24px; text-align: center;">
                            <h1 style="margin: 0; font-size: 24px; font-weight: 700; color: white; letter-spacing: -0.02em;">
                                Debit Alert
                            </h1>
                            <p style="margin: 8px 0 0; font-size: 14px; opacity: 0.95; color: rgba(255,255,255,0.9);">
                                A transaction occurred on your account
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Amount Card -->
                    <tr>
                        <td style="padding: 40px 32px 24px; text-align: center;">
                            <div style="background: linear-gradient(135deg, #f87171 0%, #ef4444 100%); color: white; padding: 32px 24px; border-radius: 20px; max-width: 320px; margin: 0 auto 32px;">
                                <div style="font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.9; margin-bottom: 8px;">
                                    Amount Debited
                                </div>
                                <div style="font-size: 32px; font-weight: 800; line-height: 1.1; letter-spacing: -0.03em;">
                                    ₦<%= amount %>
                                </div>
                            </div>
                            <div style="font-size: 15px; font-weight: 600; color: #1e293b; margin-bottom: 8px;">
                                <%= description %>
                            </div>
                            <div style="font-size: 13px; color: #64748b; margin-bottom: 24px;">
                                Reference: <strong><%= reference %></strong>
                            </div>
                            <div style="background: #f1f5f9; border-radius: 12px; padding: 16px; margin-bottom: 24px;">
                                <div style="font-size: 14px; font-weight: 600; color: #475569; margin-bottom: 4px;">
                                    New Balance
                                </div>
                                <div style="font-size: 22px; font-weight: 800; color: #1e293b;">
                                    ₦<%= newBalance %>
                                </div>
                            </div>
                        </td>
                    </tr>

                    <!-- Details -->
                    <tr>
                        <td style="padding: 0 32px 32px;">
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                                <tr>
                                    <td style="font-size: 14px; color: #64748b; padding-bottom: 16px; border-bottom: 1px solid #e2e8f0;">
                                        Account Number<br>
                                        <strong style="color: #1e293b; font-size: 16px;"><%= accountNumber %></strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-size: 14px; color: #64748b; padding: 16px 0;">
                                        Date & Time<br>
                                        <strong style="color: #1e293b; font-size: 16px;"><%= formattedDate %></strong>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <!-- CTA & Footer -->
                    <tr>
                        <td style="padding: 0 32px 40px; text-align: center;">
                            <a href="https://sfa-bank-fe.vercel.app/accounts" style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); color: white; padding: 14px 32px; border-radius: 12px; font-weight: 600; font-size: 16px; text-decoration: none; display: inline-block;">
                                View Account
                            </a>
                            <p style="font-size: 13px; color: #94a3b8; margin-top: 24px;">
                                If you didn't initiate this transaction, 
                                <a href="mailto:support@sfa-bank.com" style="color: #3b82f6;">contact support</a> immediately.
                            </p>
                            <p style="font-size: 12px; color: #94a3b8; margin: 16px 0 0;">
                                © 2024 SFA Bank. All rights reserved.
                                <br>Secure Banking | Fast Transfers
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </table>
</body>
</html>

