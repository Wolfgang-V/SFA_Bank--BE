<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SFA Bank - Login Alert</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f8fafc;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background-color: #f8fafc;">
        <tr>
            <td style="padding: 40px 20px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 600px; margin: 0 auto; background-color: white; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); overflow: hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); padding: 32px 32px 24px; text-align: center;">
                            <h1 style="margin: 0; font-size: 24px; font-weight: 700; color: white; letter-spacing: -0.02em;">
                                New Login Detected
                            </h1>
                            <p style="margin: 8px 0 0; font-size: 14px; opacity: 0.95; color: rgba(255,255,255,0.9);">
                                We noticed a login to your SFA Bank account
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Details -->
                    <tr>
                        <td style="padding: 40px 32px;">
                            <div style="font-size: 15px; font-weight: 600; color: #1e293b; margin-bottom: 24px; line-height: 1.5;">
                                Hello <%= firstName %>,
                            </div>
                            <p style="font-size: 15px; color: #475569; line-height: 1.6; margin-bottom: 24px;">
                                We detected a new login to your SFA Bank account from a new device or location.
                            </p>
                            
                            <div style="background: #f8fafc; border-radius: 12px; padding: 24px; margin: 24px 0;">
                                <h4 style="margin: 0 0 12px 0; font-size: 16px; font-weight: 700; color: #1e293b;">Login Details</h4>
                                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                                    <tr>
                                        <td style="font-size: 14px; color: #64748b; padding: 8px 0; border-bottom: 1px solid #e2e8f0;">
                                            Device
                                        </td>
                                        <td style="font-size: 14px; font-weight: 600; color: #1e293b; padding: 8px 0; border-bottom: 1px solid #e2e8f0; text-align: right;">
                                            <%= device || 'Unknown' %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="font-size: 14px; color: #64748b; padding: 8px 0;">
                                            Location
                                        </td>
                                        <td style="font-size: 14px; font-weight: 600; color: #1e293b; padding: 8px 0; text-align: right;">
                                            <%= location || 'Unknown' %>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td style="font-size: 14px; color: #64748b; padding: 8px 0 0 0;">
                                            IP Address
                                        </td>
                                        <td style="font-size: 14px; font-weight: 600; color: #1e293b; padding: 8px 0 0 0; text-align: right;">
                                            <%= ip || 'Unknown' %>
                                        </td>
                                    </tr>
                                </table>
                            </div>

                            <p style="font-size: 15px; color: #475569; line-height: 1.6; margin-bottom: 24px;">
                                If this was you, no action needed. If not, 
                                <strong style="color: #ef4444;">secure your account immediately</strong>.
                            </p>

                            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                                <a href="https://sfa-bank-fe.vercel.app/security" style="background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%); color: white; padding: 12px 24px; border-radius: 10px; font-weight: 600; text-decoration: none; font-size: 14px;">
                                    Secure Account
                                </a>
                                <a href="https://sfa-bank-fe.vercel.app/login" style="background: white; color: #3b82f6; padding: 12px 24px; border-radius: 10px; font-weight: 600; text-decoration: none; font-size: 14px; border: 2px solid #3b82f6;">
                                    Login Again
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="padding: 32px; background: #f8fafc; text-align: center; border-top: 1px solid #e2e8f0;">
                            <p style="font-size: 13px; color: #94a3b8; margin: 0;">
                                © 2024 SFA Bank. All rights reserved.<br>
                                <a href="mailto:support@sfa-bank.com" style="color: #64748b;">support@sfa-bank.com</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </table>
</body>
</html>

